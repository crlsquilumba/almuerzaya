# ============================================================================
# ALMUERZA YA - Professional .gitignore
# ============================================================================
# Last Updated: 2026-05-31
# Purpose: Exclude files that shouldn't be version controlled
# ============================================================================

# ============================================================================
# ENVIRONMENT & SECRETS
# ============================================================================

# Environment variables (NEVER commit these!)
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test

# AWS credentials
.aws/
.aws/credentials
.aws/config

# SSH Keys
*.pem
*.key
*.pub

# API Keys and tokens
**/secrets/
**/.secrets/
*.secret

# ============================================================================
# NODE.JS / NPM / YARN / PNPM
# ============================================================================

# Dependencies
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
lerna-debug.log

# npm cache
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# npm workspace
.npmrc

# Dependency management
dist/
build/
.next/
out/

# ============================================================================
# FRONTEND / REACT / VITE
# ============================================================================

# Vite build output
apps/web/dist/
apps/web/build/
apps/web/.vite/

# React build
apps/web/coverage/

# Tailwind CSS cache
.tailwindcss/

# Next.js
apps/web/.next/
apps/web/out/

# ============================================================================
# BACKEND / NODE.JS SERVER
# ============================================================================

# Build outputs
apps/backend/dist/
apps/backend/build/
apps/backend/.turbo/

# Runtime data
apps/backend/.runtime/
apps/backend/pids/
*.pid
*.seed
*.pid.lock

# Logs
logs/
*.log
lerna-debug.log

# ============================================================================
# DATABASE & DATA
# ============================================================================

# SQLite (dev databases)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Prisma generated files
prisma/.migration_lock.toml

# MongoDB
.mongod
.mongodb

# PostgreSQL
postgres_data/
pgadmin_data/

